NODE_ENV=development
PORT=3002
CLIENT_URL=http://localhost:3001

# cTrader Open API
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_REDIRECT_URI=http://localhost:3002/api/ctrader/callback
CTRADER_ENVIRONMENT=demo
CTRADER_ACCOUNT_ID=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google OAuth (future)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Database (future)
DATABASE_URL=

# Frontend (Vite) — set in client env or root Vite env as needed.
# When true, shows the bottom-right manual mock-price simulator.
# Default/absent: simulator is hidden and does not overwrite cTrader market data.
# VITE_ENABLE_MARKET_SIMULATOR=true
